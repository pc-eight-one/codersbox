# Vercel Environment Variables
# Copy this file to .env.local for development

# Vercel Analytics (automatically provided in production)
# VERCEL_ANALYTICS_ID=

# Email Service Configuration
# Choose one of the following email services:

# SendGrid (Recommended for Vercel)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@codersbox.dev
SENDGRID_TO_EMAIL=contact@codersbox.dev

# Mailgun Alternative
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_mailgun_domain_here

# Resend (Recommended Email Service)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@codersbox.dev
RESEND_TO_EMAIL=contact@codersbox.dev
RESEND_REPLY_TO=contact@codersbox.dev

# Newsletter Service (Optional)
# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_LIST_ID=your_mailchimp_list_id_here
MAILCHIMP_SERVER_PREFIX=us1

# ConvertKit Alternative
# CONVERTKIT_API_KEY=your_convertkit_api_key_here
# CONVERTKIT_FORM_ID=your_convertkit_form_id_here

# Database Configuration
# Turso Database (libSQL)
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here
DATABASE_INIT_TOKEN=your_database_init_token_here

# Alternative Database Options
# Vercel Postgres
# POSTGRES_URL=your_vercel_postgres_url_here
# POSTGRES_PRISMA_URL=your_vercel_postgres_prisma_url_here
# POSTGRES_URL_NON_POOLING=your_vercel_postgres_non_pooling_url_here

# Redis for rate limiting (Vercel KV)
# KV_URL=your_vercel_kv_url_here
# KV_REST_API_URL=your_vercel_kv_rest_api_url_here
# KV_REST_API_TOKEN=your_vercel_kv_rest_api_token_here
# KV_REST_API_READ_ONLY_TOKEN=your_vercel_kv_rest_api_read_only_token_here

# Security
# CORS_ORIGIN=https://codersbox.dev
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=3600000

# Site Configuration
SITE_URL=https://codersbox.dev
SITE_NAME=codersbox
CONTACT_EMAIL=contact@codersbox.dev

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_NEWSLETTER=true
ENABLE_CONTACT_FORM=true

# Development
NODE_ENV=development