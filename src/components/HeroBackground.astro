---

<div class="absolute inset-0 z-0 opacity-10">
  <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- Animated pattern with moving dots -->
      <pattern id="dots" width="20" height="20" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="currentColor">
          <!-- Subtle pulsing animation -->
          <animate attributeName="r"
            values="1;1.3;1"
            dur="4s"
            repeatCount="indefinite"
            begin="0s" />
        </circle>
      </pattern>

      <!-- Second pattern layer with offset timing for depth -->
      <pattern id="dots-2" width="20" height="20" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="currentColor" opacity="0.5">
          <animate attributeName="r"
            values="1;1.2;1"
            dur="3s"
            repeatCount="indefinite"
            begin="1.5s" />
        </circle>
      </pattern>
    </defs>

    <!-- Base pattern layer -->
    <rect width="100%" height="100%" fill="url(#dots)">
      <!-- Very subtle opacity pulse -->
      <animate attributeName="opacity"
        values="0.8;1;0.8"
        dur="8s"
        repeatCount="indefinite" />
    </rect>

    <!-- Offset pattern layer for shimmer effect -->
    <rect width="100%" height="100%" fill="url(#dots-2)" opacity="0.3">
      <animate attributeName="opacity"
        values="0.3;0.5;0.3"
        dur="6s"
        repeatCount="indefinite"
        begin="2s" />
    </rect>
  </svg>
</div>