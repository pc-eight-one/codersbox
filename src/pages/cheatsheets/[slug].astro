---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShareButton from '@/components/ShareButton.astro';

export async function getStaticPaths() {
  const cheatsheets = await getCollection('cheatsheets', ({ data }) => {
    return data.draft !== true && data.published !== false;
  });
  return cheatsheets.map((cheatsheet) => ({
    params: { slug: cheatsheet.slug },
    props: { cheatsheet },
  }));
}

const { cheatsheet } = Astro.props;
const { Content } = await cheatsheet.render();
---

<BaseLayout
  title={`${cheatsheet.data.title} - codersbox`}
  description={cheatsheet.data.description}
  type="article"
  publishDate={cheatsheet.data.publishDate}
  author={cheatsheet.data.author}
  tags={cheatsheet.data.tags}
  canonical={`https://codersbox.dev/cheatsheets/${cheatsheet.slug}/`}
  image={cheatsheet.data.image || '/og-image.jpg'}
>
  <main class="min-h-screen bg-gray-50">
    <!-- Cheatsheet Hero Section -->
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="text-center">
          <div class="inline-block bg-indigo-100 text-indigo-800 px-4 py-2 rounded-full text-sm font-medium mb-4">
            Quick Reference
          </div>

          <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight tracking-tight text-gray-900">
            {cheatsheet.data.title}
          </h1>

          <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto leading-relaxed">
            {cheatsheet.data.description}
          </p>

          <div class="flex flex-wrap justify-center items-center gap-6 text-sm text-gray-500 mb-6">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>{cheatsheet.data.publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>{cheatsheet.data.readTime}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <span>By {cheatsheet.data.author}</span>
            </div>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap justify-center gap-2">
            {cheatsheet.data.tags.map((tag) => (
              <span class="bg-indigo-100 text-indigo-800 px-4 py-2 rounded-full text-sm font-medium hover:bg-indigo-200 transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </header>

    <!-- Cheatsheet Content -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <!-- Downloads Section (if available) -->
      {cheatsheet.data.downloads && cheatsheet.data.downloads.length > 0 && (
        <div class="bg-gradient-to-br from-indigo-50 to-blue-50 rounded-lg border-2 border-indigo-200 p-8 mb-8 shadow-sm">
          <div class="flex items-start gap-4 mb-6">
            <div class="bg-indigo-600 rounded-lg p-3">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
            </div>
            <div class="flex-grow">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Download Cheatsheet</h2>
              <p class="text-gray-600">Get offline access to this reference guide in your preferred format</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {cheatsheet.data.downloads.map((download) => (
              <a
                href={download.url}
                download
                class="group bg-white rounded-lg border border-indigo-200 p-5 hover:border-indigo-400 hover:shadow-md transition-all duration-200 flex flex-col"
              >
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-semibold text-indigo-600 uppercase tracking-wide">
                    {download.format}
                  </span>
                  {download.size && (
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">
                      {download.size}
                    </span>
                  )}
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors">
                  {download.title}
                </h3>
                <div class="mt-auto flex items-center text-indigo-600 group-hover:text-indigo-700 text-sm font-medium">
                  Download
                  <svg class="w-4 h-4 ml-1 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <article class="bg-white rounded-lg shadow-sm border border-gray-200 px-8 py-10">
        <!-- Preview Badge -->
        <div class="mb-6">
          <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-4 py-2 rounded-full text-sm font-medium border border-blue-200">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            Preview
          </div>
        </div>

        <!-- Enhanced Cheatsheet Content with Custom Typography -->
        <div class="prose prose-lg max-w-none cheatsheet-content">
          <Content />
        </div>

        <!-- Share Section -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <div class="flex justify-between items-center">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Found this helpful?</h3>
              <p class="text-gray-600 text-sm">Share this cheatsheet with others</p>
            </div>
            <ShareButton
              title={cheatsheet.data.title}
              description={cheatsheet.data.description}
              url={`${Astro.site?.toString() || 'https://codersbox.dev'}/cheatsheets/${cheatsheet.slug}`}
              variant="button"
              showLabel={true}
            />
          </div>
        </div>
      </article>

      <!-- Back to Cheatsheets -->
      <div class="mt-8 text-center">
        <a
          href="/cheatsheets"
          class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-700 font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to All Cheatsheets
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* Custom styles for cheatsheet content */
  .cheatsheet-content {
    @apply text-gray-800;
  }

  .cheatsheet-content :global(h1) {
    @apply text-3xl font-bold mb-6 mt-8 text-gray-900 border-b-2 border-indigo-500 pb-3;
  }

  .cheatsheet-content :global(h2) {
    @apply text-2xl font-bold mb-4 mt-8 text-gray-900 border-l-4 border-indigo-500 pl-4;
  }

  .cheatsheet-content :global(h3) {
    @apply text-xl font-bold mb-3 mt-6 text-gray-800;
  }

  .cheatsheet-content :global(h4) {
    @apply text-lg font-semibold mb-2 mt-4 text-gray-800;
  }

  .cheatsheet-content :global(p) {
    @apply mb-4 leading-relaxed;
  }

  .cheatsheet-content :global(ul),
  .cheatsheet-content :global(ol) {
    @apply mb-6 ml-6 space-y-2;
  }

  .cheatsheet-content :global(li) {
    @apply leading-relaxed;
  }

  .cheatsheet-content :global(code) {
    @apply bg-gray-100 px-2 py-1 rounded text-sm font-mono text-indigo-700 border border-gray-200;
  }

  .cheatsheet-content :global(pre) {
    @apply bg-gray-900 text-gray-100 p-6 rounded-lg overflow-x-auto mb-6 border border-gray-700 shadow-inner;
  }

  .cheatsheet-content :global(pre code) {
    @apply bg-transparent p-0 border-0 text-gray-100;
  }

  .cheatsheet-content :global(blockquote) {
    @apply border-l-4 border-indigo-500 pl-4 italic my-6 text-gray-700 bg-indigo-50 py-2 pr-4 rounded-r;
  }

  .cheatsheet-content :global(table) {
    @apply w-full mb-6 border-collapse;
  }

  .cheatsheet-content :global(th) {
    @apply bg-indigo-600 text-white font-semibold p-3 text-left border border-indigo-700;
  }

  .cheatsheet-content :global(td) {
    @apply p-3 border border-gray-300 bg-white;
  }

  .cheatsheet-content :global(tr:nth-child(even) td) {
    @apply bg-gray-50;
  }

  .cheatsheet-content :global(a) {
    @apply text-indigo-600 hover:text-indigo-700 underline font-medium;
  }

  .cheatsheet-content :global(strong) {
    @apply font-bold text-gray-900;
  }

  .cheatsheet-content :global(hr) {
    @apply my-8 border-t-2 border-gray-200;
  }
</style>
